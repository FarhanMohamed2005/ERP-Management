# Environment Configuration - PRODUCTION
NODE_ENV=production

# Server Configuration
PORT=5000

# Database Configuration
# Use MongoDB Atlas or managed MongoDB service
MONGODB_URI=mongodb+srv://prod_user:secure_password@prod-cluster.mongodb.net/erp_management_prod?retryWrites=true&w=majority

# JWT Configuration
# Generate a strong secret using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_very_secure_random_production_jwt_secret_here_minimum_64_hex_chars
JWT_EXPIRE=7d

# CORS Configuration
# Set to your production domain(s)
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Email Service (Gmail or SendGrid)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=your_app_password_not_regular_password
FROM_EMAIL=noreply@yourdomain.com
FROM_NAME=ERP Management

# Gemini AI Configuration
GEMINI_API_KEY=your_gemini_api_key_here

# File Upload Configuration
MAX_FILE_SIZE_MB=10
ALLOWED_FILE_TYPES=.csv,.xlsx,.xls

# Logging Configuration
LOG_LEVEL=warn
LOG_FILE=/var/log/erp/app.log
